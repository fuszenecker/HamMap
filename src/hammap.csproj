<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UserSecretsId>dotnet-hammap-fae54ac4-8e7a-43e4-888d-9355651441fe</UserSecretsId>
    <InvariantGlobalization>true</InvariantGlobalization>
  </PropertyGroup>

  <ItemGroup>
    <!-- Bundle the data files next to the app so it runs fully offline. -->
    <Content Include="data\callbook.xml" CopyToOutputDirectory="PreserveNewest" />
    <Content Include="data\HU.txt" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>

</Project>
